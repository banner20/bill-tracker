# Copy this file to ".env" and change the values before sharing the app.

# Password used by anyone entering bills (the phone interface)
ENTRY_PASSWORD=bills123

# Password for the finance / accounts dashboard.
# Finance login can do everything the entry login can, plus see the dashboard.
FINANCE_PASSWORD=finance123

# Secret used to sign login cookies. Set this to a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Port the server listens on
PORT=3000

# Default currency symbol shown in the UI
CURRENCY=₹

# Comma-separated default "bill type" chips that are always present and pinned.
# e.g. DEFAULT_TAGS=3061,Rent,Electricity
DEFAULT_TAGS=3061

# --- Optional: live mirror to a Google Sheet (with photos) ----------------
# Leave blank to disable. To enable, deploy google-apps-script.gs as a Web App
# from inside your Google Sheet and paste its /exec URL here (see README).
SHEETS_WEBHOOK_URL=
# Must match the SECRET you set in the Apps Script (Project Settings > Script properties)
SHEETS_WEBHOOK_SECRET=
