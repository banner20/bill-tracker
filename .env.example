# Copy this file to ".env" and change the values before sharing the app.
# On Vercel, set these same keys under Project Settings > Environment Variables.

# Password used by anyone entering bills (the phone interface)
ENTRY_PASSWORD=bills123

# Password for the finance / accounts dashboard.
# Finance login can do everything the entry login can, plus see the dashboard.
FINANCE_PASSWORD=finance123

# Secret used to sign login cookies. Set this to a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Port the server listens on (local only; Vercel sets its own)
PORT=3000

# Default currency symbol shown in the UI
CURRENCY=₹

# --- Database: Supabase Postgres -----------------------------------------
# Supabase dashboard > Project Settings > Database > Connection string.
# Use the "Transaction pooler" URI (host has ...pooler.supabase.com, port 6543)
# for serverless/Vercel. Include your DB password and ?sslmode=require.
DATABASE_URL=postgresql://postgres.xxxx:YOUR-DB-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# --- File storage: Supabase Storage --------------------------------------
# Both values come from your Supabase project:
#   SUPABASE_URL  → Project Settings > API > "Project URL"
#   SUPABASE_SERVICE_KEY → Project Settings > API > "service_role" secret key
# (The app auto-creates the "attachments" bucket on first run.)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# Comma-separated default "bill type" chips that are always present and pinned.
# e.g. DEFAULT_TAGS=3061,Rent,Electricity
DEFAULT_TAGS=3061

# --- Google Sheets live export (optional) ---------------------------------
# Any random string — used to authenticate the public CSV URL for IMPORTDATA().
# Once set, click "Sheets ↗" in the dashboard to get the formula to paste.
EXPORT_TOKEN=

# --- Telegram bot (optional) ----------------------------------------------
# Create a bot via @BotFather on Telegram, copy the token here.
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram chat IDs allowed to submit bills (leave blank = anyone).
# Send /start to the bot to see your chat ID.
TELEGRAM_ALLOWED_CHATS=

# --- Groq AI (optional, powers bill parsing in Telegram bot) --------------
# Free API key at console.groq.com — used to parse bill text and photos.
GROQ_API_KEY=

# --- Optional: live mirror to a Google Sheet (with photos) ----------------
# Leave blank to disable. To enable, deploy google-apps-script.gs as a Web App
# from inside your Google Sheet and paste its /exec URL here (see README).
SHEETS_WEBHOOK_URL=
# Must match the SECRET you set in the Apps Script (Project Settings > Script properties)
SHEETS_WEBHOOK_SECRET=
